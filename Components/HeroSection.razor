<section id="home" class="hero">
    <div class="container hero-grid">
        <div class="hero-copy">
            <span class="eyebrow">Portfolio</span>
            <p class="hero-name">@Profile.Name</p>
            <h1>@Profile.Headline</h1>
            <p class="hero-subtitle">@Profile.Subtitle</p>
            <p class="hero-support">@Profile.Summary</p>

            <div class="hero-actions">
                <a class="btn btn-primary" href="#experience">View Experience</a>
                <a class="btn btn-secondary" href="#skills">Technical Skills</a>
                <a class="btn btn-secondary" href="#projects">Featured Projects</a>
                <a class="btn btn-secondary" href="#contact">Contact Me</a>
                @if (cvAvailable)
                {
                    <a class="btn btn-ghost" href="@Contact.CvUrl" target="_blank" rel="noopener" download>Download CV</a>
                }
                else
                {
                    <button class="btn btn-ghost" type="button" disabled>Download CV</button>
                }
            </div>
        </div>

        <div class="hero-panel" aria-label="Professional highlights">
            <div class="hero-role">
                <span>@Profile.Role</span>
                <strong>@Profile.Location</strong>
            </div>
            <div class="highlight-grid">
                @foreach (var highlight in Profile.Highlights)
                {
                    <article class="highlight-card">
                        <span>@highlight</span>
                    </article>
                }
            </div>
        </div>
    </div>
</section>

@code {
    [Inject] private HttpClient HttpClient { get; set; } = default!;

    [Parameter] public ProfileInfo Profile { get; set; } = new();
    [Parameter] public ContactInfo Contact { get; set; } = new();

    private bool cvAvailable;
    private string checkedCvUrl = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        if (checkedCvUrl == Contact.CvUrl)
        {
            return;
        }

        checkedCvUrl = Contact.CvUrl;
        cvAvailable = await UrlExistsAsync(Contact.CvUrl);
    }

    private async Task<bool> UrlExistsAsync(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return false;
        }

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Head, url);
            using var response = await HttpClient.SendAsync(request);
            return response.IsSuccessStatusCode;
        }
        catch
        {
            return false;
        }
    }
}

