<section id="contact" class="section contact-section">
    <div class="container contact-grid">
        <div>
            <SectionTitle Eyebrow="Contact" Title="Backend .NET opportunities" Description="@Contact.Message" />
            <p class="contact-note">Interested in backend .NET opportunities focused on enterprise systems, APIs, integrations, cloud services, and application modernization.</p>
        </div>

        <div class="contact-card">
            <div class="contact-row">
                <span>Location</span>
                <strong>@Contact.Location</strong>
            </div>
            <div class="contact-row">
                <span>Availability</span>
                <strong>@Contact.Availability</strong>
            </div>
            <div class="contact-actions">
                @if (HasConfiguredEmail)
                {
                    <a class="btn btn-primary" href="mailto:@Contact.Email">Contact Me</a>
                }
                else
                {
                    <a class="btn btn-primary" href="@Contact.LinkedIn" target="_blank" rel="noopener">Contact Me</a>
                }
                <a class="btn btn-secondary" href="@Contact.LinkedIn" target="_blank" rel="noopener">LinkedIn</a>
                <a class="btn btn-secondary" href="@Contact.GitHub" target="_blank" rel="noopener">GitHub</a>
                @if (cvAvailable)
                {
                    <a class="btn btn-ghost" href="@Contact.CvUrl" target="_blank" rel="noopener" download>Download CV</a>
                }
                else
                {
                    <button class="btn btn-ghost" type="button" disabled>Download CV</button>
                }
            </div>
        </div>
    </div>
</section>

@code {
    [Inject] private HttpClient HttpClient { get; set; } = default!;

    [Parameter] public ContactInfo Contact { get; set; } = new();

    private bool cvAvailable;
    private string checkedCvUrl = string.Empty;

    private bool HasConfiguredEmail =>
        !string.IsNullOrWhiteSpace(Contact.Email)
        && Contact.Email.Contains('@')
        && !Contact.Email.Contains("example", StringComparison.OrdinalIgnoreCase)
        && !Contact.Email.Contains("placeholder", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnParametersSetAsync()
    {
        if (checkedCvUrl == Contact.CvUrl)
        {
            return;
        }

        checkedCvUrl = Contact.CvUrl;
        cvAvailable = await UrlExistsAsync(Contact.CvUrl);
    }

    private async Task<bool> UrlExistsAsync(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return false;
        }

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Head, url);
            using var response = await HttpClient.SendAsync(request);
            return response.IsSuccessStatusCode;
        }
        catch
        {
            return false;
        }
    }
}

