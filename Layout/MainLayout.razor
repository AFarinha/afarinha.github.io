@inherits LayoutComponentBase

<div class="@ThemeClass">
    <NavMenu IsDarkMode="@isDarkMode" OnToggleTheme="@ToggleTheme" />
    <main>
        @Body
    </main>
</div>

@code {
    private bool isDarkMode = true;
    private string ThemeClass => isDarkMode ? "site-shell dark-theme" : "site-shell light-theme";

    private void ToggleTheme()
    {
        isDarkMode = !isDarkMode;
    }
}


