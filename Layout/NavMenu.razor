<header class="site-header">
    <div class="nav-container">
        <a class="brand" href="#home" aria-label="Andre Farinha home">
            <span class="brand-mark">AF</span>
            <span>
                <strong>AndrÃ© Farinha</strong>
                <small>Senior .NET Backend Developer</small>
            </span>
        </a>

        <button class="menu-button" type="button" @onclick="ToggleNavMenu" aria-label="Toggle navigation" aria-expanded="@(!collapseNavMenu)">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <nav class="@NavMenuCssClass" aria-label="Main navigation">
            <a href="#about">About</a>
            <a href="#experience">Experience</a>
            <a href="#skills">Skills</a>
            <a href="#projects">Projects</a>
            <a href="#certifications">Certifications</a>
            <a href="#contact">Contact</a>
            <button class="theme-toggle" type="button" @onclick="OnToggleTheme">
                @(IsDarkMode ? "Light" : "Dark")
            </button>
        </nav>
    </div>
</header>

@code {
    [Parameter] public bool IsDarkMode { get; set; }
    [Parameter] public EventCallback OnToggleTheme { get; set; }

    private bool collapseNavMenu = true;
    private string NavMenuCssClass => collapseNavMenu ? "nav-links collapsed" : "nav-links";

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}


